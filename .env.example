# =============================================================================
# Variables de Entorno - Nuxt Prisma Auth Template
# =============================================================================

# ---------------------------------------------------------------------------
# Base de datos PostgreSQL
# ---------------------------------------------------------------------------
DB_USER=app_user
DB_PASSWORD=tu_password_seguro_aqui
DB_NAME=app_database

# URL completa para Prisma (se construye automáticamente en docker-compose)
# Para desarrollo local sin Docker:
# DATABASE_URL="postgresql://app_user:password@localhost:5432/app_database?schema=public"

# ---------------------------------------------------------------------------
# Seguridad - IMPORTANTE: Cambiar en producción!
# ---------------------------------------------------------------------------
# Mínimo 32 caracteres para la clave de sesión
NUXT_SESSION_PASSWORD=cambia-esto-por-una-clave-muy-segura-de-minimo-32-caracteres

# ---------------------------------------------------------------------------
# OAuth (Opcional)
# ---------------------------------------------------------------------------
# NUXT_OAUTH_GOOGLE_CLIENT_ID=
# NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
