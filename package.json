{
  "name": "nuxt-prisma-auth-role-template",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Plantilla base Nuxt 4 + Prisma + Autenticación + Roles",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:setup": "prisma migrate dev --name init && prisma db seed",
    "prisma:seed": "prisma db seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  },
  "dependencies": {
    "@nuxt/icon": "^1.11.0",
    "@pinia/nuxt": "^0.11.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^13.0.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.483.0",
    "nuxt": "^4.2.1",
    "nuxt-auth-utils": "^0.5.25",
    "pg": "^8.20.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.6.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@iconify-json/lucide": "^1.2.99",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.18",
    "@types/pg": "^8.20.0",
    "prisma": "^7.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.1",
    "vitest": "^3.1.3"
  },
  "packageManager": "pnpm@10.12.1"
}
